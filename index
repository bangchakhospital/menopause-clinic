<html lang="th"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>แบบประเมินวัยทอง | Menopause Clinic Assessment</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet">
  <style>
    *{font-family:'Sarabun',sans-serif}
    html{scroll-behavior:smooth}
    .glass{background:rgba(255,255,255,.78);backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.55)}
    .card{border-radius:24px;box-shadow:0 20px 50px rgba(15,23,42,.09)}
    .section{display:none}.section.active{display:block}
    .tab.active{background:#ec4899;color:white;box-shadow:0 12px 24px rgba(236,72,153,.28)}
    .scoreBtn input{display:none}.scoreBtn span{display:inline-flex;align-items:center;justify-content:center;width:38px;height:34px;border-radius:14px;border:1px solid #fbcfe8;background:white;color:#831843;font-weight:700;cursor:pointer}.scoreBtn input:checked+span{background:#ec4899;color:white;border-color:#ec4899}
    @media print{
      body{background:white!important;color:#111827!important}
      .no-print,.tabbar,.hero,.floating{display:none!important}
      .print-area{display:block!important;box-shadow:none!important;border:0!important;background:white!important}
      .section{display:block!important;page-break-inside:avoid;margin-bottom:20px}
      input,select,textarea{border:0!important;background:white!important;padding:0!important}
      .card,.glass{box-shadow:none!important;border:1px solid #ddd!important;background:white!important}
      .page-break{page-break-before:always}
    }
  </style>
