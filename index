      <div id="boneItems" class="grid md:grid-cols-2 gap-2"><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone0" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>อายุ ≥65 ปี</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone1" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>หมดประจำเดือนก่อนอายุ 45 ปี</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone2" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>พ่อแม่เคยสะโพกหัก</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone3" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>เคยกระดูกหักจากอุบัติเหตุเล็กน้อย</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone4" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>BMI &lt;19</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone5" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>สูบบุหรี่</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone6" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>ดื่มแอลกอฮอล์มาก</span></label><label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="bone7" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>ใช้สเตียรอยด์ต่อเนื่อง ≥3 เดือน</span></label></div>
      <div class="mt-5 p-4 rounded-2xl bg-orange-50"><b>ผลประเมิน:</b> <span id="boneResult">ยังไม่พบปัจจัยเสี่ยงสำคัญ</span></div>
    </section>

    <section id="cvd" class="section glass card p-6 mb-5">
      <div class="flex justify-between items-center mb-4"><h2 class="text-2xl font-extrabold">6) ความเสี่ยงหัวใจและเมตาบอลิก</h2><button onclick="printSection('cvd')" class="no-print px-4 py-2 bg-slate-900 text-white rounded-xl">พิมพ์ส่วนนี้</button></div>
      <div class="grid md:grid-cols-4 gap-4">
        <label>SBP<input id="sbp" type="number" class="w-full mt-1 p-3 rounded-xl border" oninput="calculate()"></label>
        <label>DBP<input id="dbp" type="number" class="w-full mt-1 p-3 rounded-xl border" oninput="calculate()"></label>
        <label>FBS<input id="fbs" type="number" class="w-full mt-1 p-3 rounded-xl border" oninput="calculate()"></label>
        <label>HbA1c<input id="a1c" type="number" step="0.1" class="w-full mt-1 p-3 rounded-xl border" oninput="calculate()"></label>
        <label>LDL<input id="ldl" type="number" class="w-full mt-1 p-3 rounded-xl border"></label>
        <label>HDL<input id="hdl" type="number" class="w-full mt-1 p-3 rounded-xl border"></label>
        <label>TG<input id="tg" type="number" class="w-full mt-1 p-3 rounded-xl border"></label>
        <label>สูบบุหรี่<select id="smoke" class="w-full mt-1 p-3 rounded-xl border" onchange="calculate()"><option value="0">ไม่สูบ</option><option value="1">สูบ</option></select></label>
      </div>
      <div class="mt-5 p-4 rounded-2xl bg-pink-50"><b>ผลประเมิน:</b> <span id="cvdResult">ยังไม่พบสัญญาณเสี่ยงเด่นจากข้อมูลที่กรอก</span></div>
    </section>

    <section id="screen" class="section glass card p-6 mb-5 active">
      <div class="flex justify-between items-center mb-4"><h2 class="text-2xl font-extrabold">7) ตรวจคัดกรองที่ควรทบทวน</h2><button onclick="printSection('screen')" class="no-print px-4 py-2 bg-slate-900 text-white rounded-xl">พิมพ์ส่วนนี้</button></div>
      <div id="screenItems" class="grid md:grid-cols-2 gap-3"><label class="p-3 rounded-2xl bg-white/70 border block"><b>Pap smear / HPV DNA</b><select id="screen0" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>Mammogram</b><select id="screen1" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>ตรวจเต้านมโดยแพทย์</b><select id="screen2" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>FIT/Colonoscopy ตามอายุ/ความเสี่ยง</b><select id="screen3" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>Bone mineral density (BMD)</b><select id="screen4" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>Lipid profile</b><select id="screen5" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>FBS/HbA1c</b><select id="screen6" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label><label class="p-3 rounded-2xl bg-white/70 border block"><b>วัคซีนที่เหมาะสม เช่น Influenza, Tdap, Zoster</b><select id="screen7" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label></div>
    </section>

    <section id="summary" class="section glass card p-6 mb-5">
      <div class="flex justify-between items-center mb-4"><h2 class="text-2xl font-extrabold">8) สรุปผลและแผนดูแล</h2><button onclick="printSection('summary')" class="no-print px-4 py-2 bg-slate-900 text-white rounded-xl">พิมพ์ส่วนนี้</button></div>
      <div id="summaryBox" class="space-y-3"><div class="p-5 rounded-2xl bg-pink-100"><h3 class="font-extrabold text-xl">กลุ่มสรุป: A: อาการเล็กน้อย</h3><p>MRS รวม 1 (ไม่มี/น้อยมาก), GSM รวม 0 (ไม่พบอาการ)</p></div><div class="p-5 rounded-2xl bg-white border"><b>แนวทางเบื้องต้น:</b><br>• ให้สุขศึกษาเรื่องวัยทอง นอนหลับ ออกกำลังกาย เวทเทรนนิง โภชนาการ ควบคุมน้ำหนัก และลดแอลกอฮอล์/บุหรี่</div><div class="p-5 rounded-2xl bg-orange-50"><b>แผนแพทย์:</b><br>-</div></div>
      <label class="block mt-5 font-bold">แผนการรักษา / หมายเหตุแพทย์<textarea id="doctorPlan" class="w-full mt-2 p-3 rounded-xl border min-h-[130px]" oninput="calculate()" placeholder="เช่น ปรับพฤติกรรม / local estrogen / non-hormonal / MHT / ส่งตรวจเพิ่มเติม"></textarea></label>
    </section>
  </main>

<script>
const mrs=[['ร้อนวูบวาบ / เหงื่อออกกลางคืน','somatic'],['ใจสั่น','somatic'],['นอนไม่หลับ','somatic'],['ปวดข้อ ปวดกล้ามเนื้อ','somatic'],['ซึมเศร้า / อารมณ์ตก','psy'],['หงุดหงิด','psy'],['วิตกกังวล','psy'],['เหนื่อยง่าย / พลังงานลดลง','psy'],['ช่องคลอดแห้ง','uro'],['เจ็บขณะมีเพศสัมพันธ์','uro'],['ปัสสาวะบ่อย / กลั้นปัสสาวะไม่อยู่','uro']];
const gsm=['ช่องคลอดแห้ง','แสบ คัน ระคายเคือง','ปัสสาวะแสบขัด','ปัสสาวะบ่อย','กลั้นปัสสาวะไม่อยู่','เจ็บเวลามีเพศสัมพันธ์'];
const indications=['ร้อนวูบวาบรบกวนชีวิต','เหงื่อออกกลางคืน/นอนไม่หลับจากวัยทอง','GSM หรือช่องคลอดแห้ง','ต้องการป้องกันกระดูกพรุนในรายที่เหมาะสม'];
const contra=['มะเร็งเต้านมหรือสงสัย','มะเร็งเยื่อบุโพรงมดลูกหรือสงสัย','เลือดออกผิดปกติจากโพรงมดลูกยังไม่ทราบสาเหตุ','เคยลิ่มเลือดอุดตัน DVT/PE','เคย Stroke / MI','โรคตับรุนแรง','ตั้งครรภ์หรือสงสัยตั้งครรภ์'];
const bone=['อายุ ≥65 ปี','หมดประจำเดือนก่อนอายุ 45 ปี','พ่อแม่เคยสะโพกหัก','เคยกระดูกหักจากอุบัติเหตุเล็กน้อย','BMI <19','สูบบุหรี่','ดื่มแอลกอฮอล์มาก','ใช้สเตียรอยด์ต่อเนื่อง ≥3 เดือน'];
const screens=['Pap smear / HPV DNA','Mammogram','ตรวจเต้านมโดยแพทย์','FIT/Colonoscopy ตามอายุ/ความเสี่ยง','Bone mineral density (BMD)','Lipid profile','FBS/HbA1c','วัคซีนที่เหมาะสม เช่น Influenza, Tdap, Zoster'];
function scoreRow(name,i,max=4){let h=`<div class="flex flex-col md:flex-row md:items-center justify-between gap-3 p-3 rounded-2xl bg-white/70 border"><b>${i+1}. ${name}</b><div class="flex gap-1">`;for(let s=0;s<=max;s++)h+=`<label class="scoreBtn"><input type="radio" name="${name+i}" value="${s}" ${s==0?'checked':''} onchange="calculate()"><span>${s}</span></label>`;return h+'</div></div>'}
function checkRow(id,text){return `<label class="flex gap-2 items-start p-3 rounded-2xl bg-white/70 border"><input id="${id}" type="checkbox" class="mt-1 scale-125" onchange="calculate()"><span>${text}</span></label>`}
function init(){document.getElementById('date').valueAsDate=new Date();document.getElementById('mrsItems').innerHTML=mrs.map((x,i)=>scoreRow(x[0],i,4)).join('');document.getElementById('gsmItems').innerHTML=gsm.map((x,i)=>scoreRow(x,i,3)).join('');document.getElementById('mhtIndications').innerHTML=indications.map((x,i)=>checkRow('ind'+i,x)).join('');document.getElementById('mhtContra').innerHTML=contra.map((x,i)=>checkRow('con'+i,x)).join('');document.getElementById('boneItems').innerHTML=bone.map((x,i)=>checkRow('bone'+i,x)).join('');document.getElementById('screenItems').innerHTML=screens.map((x,i)=>`<label class="p-3 rounded-2xl bg-white/70 border block"><b>${x}</b><select id="screen${i}" class="w-full mt-2 p-2 rounded-xl border"><option>ยังไม่ทราบ/ต้องทบทวน</option><option>ทำแล้ว</option><option>นัดตรวจ</option><option>ไม่เข้าเกณฑ์</option></select></label>`).join('');loadData();calculate()}
function val(id){return document.getElementById(id)?.value||''}function num(id){return parseFloat(val(id))||0}
function checkedCount(prefix,n){let c=0;for(let i=0;i<n;i++)if(document.getElementById(prefix+i)?.checked)c++;return c}
function radioSum(container){return [...document.querySelectorAll('#'+container+' input[type=radio]:checked')].reduce((a,e)=>a+Number(e.value),0)}
function calculate(){let w=num('weight'),h=num('height');let bmi=h? w/((h/100)**2):0;document.getElementById('bmiText').textContent=bmi?bmi.toFixed(1)+(bmi<18.5?' น้ำหนักน้อย':bmi<23?' ปกติ':bmi<25?' น้ำหนักเกิน':' อ้วน'):'-';let status=val('menoStatus');document.getElementById('stageText').textContent=status;document.getElementById('patientNote').textContent=num('age')>=45?'อยู่ในช่วงควรประเมินอาการวัยทองและโรคร่วม':'อายุน้อย ควรหาสาเหตุอื่นร่วมด้วย';let som=0,psy=0,uro=0;document.querySelectorAll('#mrsItems input[type=radio]:checked').forEach((e,i)=>{let v=+e.value;if(mrs[i]?.[1]=='somatic')som+=v;if(mrs[i]?.[1]=='psy')psy+=v;if(mrs[i]?.[1]=='uro')uro+=v});let total=som+psy+uro;let lvl=total<=4?'ไม่มี/น้อยมาก':total<=8?'เล็กน้อย':total<=16?'ปานกลาง':'รุนแรง';mrsSomatic.textContent=som;mrsPsy.textContent=psy;mrsUro.textContent=uro;mrsTotal.textContent=total;mrsLevel.textContent=lvl;let gt=radioSum('gsmItems');gsmTotal.textContent=gt;gsmLevel.textContent=gt==0?'ไม่พบอาการ':gt<=5?'เล็กน้อย':gt<=10?'ปานกลาง':'มาก';let ind=checkedCount('ind',indications.length),con=checkedCount('con',contra.length);mhtResult.textContent=con?'พบข้อห้าม/ข้อควรระวัง ควรประเมินเพิ่มเติมก่อนใช้ MHT':ind?'มีข้อบ่งชี้ อาจพิจารณา MHT หากไม่มีข้อห้ามและประเมินความเสี่ยงแล้ว':'ยังไม่มีข้อบ่งชี้ชัดเจน';let bc=checkedCount('bone',bone.length);boneResult.textContent=bc?'พบปัจจัยเสี่ยง '+bc+' ข้อ ควรพิจารณา BMD/FRAX และแนะนำแคลเซียม วิตามินดี ออกกำลังลงน้ำหนัก':'ยังไม่พบปัจจัยเสี่ยงสำคัญ';let risk=[];if(num('sbp')>=140||num('dbp')>=90)risk.push('ความดันสูง');if(num('fbs')>=126||num('a1c')>=6.5)risk.push('เข้าเกณฑ์เบาหวาน/ควรยืนยัน');if(val('smoke')==='1')risk.push('สูบบุหรี่');cvdResult.textContent=risk.length?risk.join(', ')+' — ควรประเมินความเสี่ยง CVD ก่อนเลือก MHT':'ยังไม่พบสัญญาณเสี่ยงเด่นจากข้อมูลที่กรอก';let group= con?'D: พบข้อห้าม/ต้องประเมินก่อน': total>=17?'C: อาการรุนแรง': total>=9?'B: อาการปานกลาง':'A: อาการเล็กน้อย';summaryBox.innerHTML=`<div class="p-5 rounded-2xl bg-pink-100"><h3 class="font-extrabold text-xl">กลุ่มสรุป: ${group}</h3><p>MRS รวม ${total} (${lvl}), GSM รวม ${gt} (${gsmLevel.textContent})</p></div><div class="p-5 rounded-2xl bg-white border"><b>แนวทางเบื้องต้น:</b><br>${makeAdvice(total,gt,con,ind,bc,risk)}</div><div class="p-5 rounded-2xl bg-orange-50"><b>แผนแพทย์:</b><br>${(val('doctorPlan')||'-').replaceAll('\n','<br>')}</div>`}
function makeAdvice(total,gt,con,ind,bc,risk){let a=[];a.push('ให้สุขศึกษาเรื่องวัยทอง นอนหลับ ออกกำลังกาย เวทเทรนนิง โภชนาการ ควบคุมน้ำหนัก และลดแอลกอฮอล์/บุหรี่');if(total>=9&&!con)a.push('พิจารณา non-hormonal หรือ MHT หลังซักประวัติ ตรวจร่างกาย และอธิบายประโยชน์/ความเสี่ยง');if(gt>=6)a.push('หากเด่นเรื่อง GSM พิจารณา moisturizer/lubricant และ local vaginal estrogen/DHEA ตามความเหมาะสม');if(con)a.push('ยังไม่ควรเริ่ม MHT จนกว่าจะประเมินข้อห้ามหรือส่งต่อครบถ้วน');if(bc)a.push('ประเมิน BMD/FRAX ตามข้อบ่งชี้');if(risk.length)a.push('ควบคุมปัจจัยเสี่ยงหัวใจและเมตาบอลิกก่อน/ระหว่างรักษา');return a.map(x=>'• '+x).join('<br>')}
function showSection(id,btn){document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));btn.classList.add('active');calculate()}
function printSection(id){calculate();document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');setTimeout(()=>window.print(),100)}
function printAll(){calculate();document.querySelectorAll('.section').forEach(s=>s.classList.add('active'));setTimeout(()=>window.print(),100)}
function saveData(){let data={};document.querySelectorAll('input,select,textarea').forEach(el=>{if(el.type==='radio'){if(el.checked)data[el.name]=el.value}else if(el.type==='checkbox')data[el.id]=el.checked;else data[el.id]=el.value});localStorage.setItem('menopauseAssessment',JSON.stringify(data));alert('บันทึกข้อมูลในเครื่องแล้ว')}
function loadData(){let data=JSON.parse(localStorage.getItem('menopauseAssessment')||'{}');document.querySelectorAll('input,select,textarea').forEach(el=>{if(el.type==='radio'){if(data[el.name]===el.value)el.checked=true}else if(el.type==='checkbox')el.checked=!!data[el.id];else if(data[el.id])el.value=data[el.id]})}
window.onload=init;
</script>


</body></html>
